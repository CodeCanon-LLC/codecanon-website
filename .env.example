# Add all these variables in repo "Secrets and variables" > "Actions"
# https://github.com/CodeCanon-LLC/codecanon-website/settings/secrets/actions
# Add to .github/workflows/deploy.yaml

VITE_GOOGLE_FONTS_API_KEY=<API_KEY>
NPM_TOKEN=<API_TOKEN>

# Stripe Payment Links (create these in the Stripe Dashboard)
# Each link must have a custom field with key "your_npm_username" and metadata:
#   waraq link  → metadata: packages=waraq
#   nuska link  → metadata: packages=nuska
#   bundle link → metadata: packages=waraq,nuska
# Set the success URL to https://codecanon.dev/purchase/success
VITE_STRIPE_PAYMENT_LINK_WARAQ=https://buy.stripe.com/<LINK_ID>
VITE_STRIPE_PAYMENT_LINK_NUSKA=https://buy.stripe.com/<LINK_ID>
VITE_STRIPE_PAYMENT_LINK_BUNDLE=https://buy.stripe.com/<LINK_ID>

# Purchase worker URL (Cloudflare Worker) — prices are fetched at runtime from this endpoint
VITE_PRICES_WORKER_URL=https://codecanon-purchase-worker.<your-subdomain>.workers.dev